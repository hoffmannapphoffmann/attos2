rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Imagens dos produtos: leitura pública, escrita apenas admin
    match /produtos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
      allow delete: if request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Música de fundo: leitura pública, escrita apenas admin
    match /musica/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
      allow delete: if request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Negar todo o resto
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
